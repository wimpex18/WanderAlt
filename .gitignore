# Local dev secrets — never commit. Cloud sessions set these as env vars
# in the cloud environment settings instead.
local-secrets.js

# Personal Claude Code settings (machine-specific permissions, etc.)
.claude/settings.local.json
CLAUDE.local.md

# Reference archive (wireframes, market research) — kept on disk, not synced
# to the cloud repo to keep clones light.
docs/archive/

# Node / npx caches
node_modules/

# macOS
.DS_Store

# Local screenshots from the puppeteer smoke-test (keep shoot.js, drop PNGs).
# Curated baseline lives at docs/screenshots/baseline/ (versioned).
.screenshots/*.png

# Full Lighthouse reports (regenerated via `npm run lighthouse`). Keep
# only the lightweight summary.json which captures the four scores per page.
docs/lighthouse/*.json
!docs/lighthouse/summary.json
.screenshots/audit/
